  toPrimaryIndex               Decimal?              @map("to_primary_index") @db.Decimal(14, 3)
  fromSecondaryIndex           Decimal?              @map("from_secondary_index") @db.Decimal(14, 3)
  toSecondaryIndex             Decimal?              @map("to_secondary_index") @db.Decimal(14, 3)
