model TariffPlan {
  id                  String               @id @default(uuid()) @db.Uuid
  code                String               @unique
  name                String
  description         String?
  zoneId              String?              @map("zone_id") @db.Uuid
  billingMode         TariffBillingMode    @default(SINGLE_RATE) @map("billing_mode")
  usageCategory       ServiceUsageCategory @default(RESIDENTIAL) @map("usage_category")
  subscribedPowerUnit ServicePowerUnit     @default(AMPERE) @map("subscribed_power_unit")
  subscribedPowerMin  Decimal?             @map("subscribed_power_min") @db.Decimal(10, 3)
  subscribedPowerMax  Decimal?             @map("subscribed_power_max") @db.Decimal(10, 3)
  phaseType           ServicePhaseType?    @map("phase_type")
  currency            String               @default("XAF")
  singleUnitPrice     Decimal?             @map("single_unit_price") @db.Decimal(14, 3)
  hpUnitPrice         Decimal?             @map("hp_unit_price") @db.Decimal(14, 3)
  hcUnitPrice         Decimal?             @map("hc_unit_price") @db.Decimal(14, 3)
  fixedCharge         Decimal              @default(0) @map("fixed_charge") @db.Decimal(14, 2)
  taxPercent          Decimal              @default(0) @map("tax_percent") @db.Decimal(5, 2)
  lateFeePercent      Decimal              @default(0) @map("late_fee_percent") @db.Decimal(5, 2)
  effectiveFrom       DateTime?            @map("effective_from")
  effectiveTo         DateTime?            @map("effective_to")
  isDefault           Boolean              @default(false) @map("is_default")
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  deletedAt           DateTime?            @map("deleted_at")
  serviceZone         Zone?                @relation(fields: [zoneId], references: [id])
  tiers               TariffTier[]
  taxes               TariffPlanTax[]
  campaigns           BillingCampaign[]
  invoices            Invoice[]

  @@index([isActive, isDefault])
  @@index([zoneId, usageCategory, billingMode, subscribedPowerUnit, phaseType])
  @@index([effectiveFrom, effectiveTo])
  @@index([deletedAt])
  @@map("tariff_plans")
}

