generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CLIENT
  AGENT
  SUPERVISOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum MeterType {
  SINGLE_INDEX
  DUAL_INDEX
}

enum MeterStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  REPLACED
}

enum MeterAssignmentSource {
  ADMIN
  IMPORT
  MOBILE_CLAIM
  SYSTEM
}

enum ReadingSource {
  CLIENT
  AGENT
  SYSTEM
}

enum ReadingStatus {
  DRAFT
  PENDING
  FLAGGED
  REJECTED
  VALIDATED
  RESUBMISSION_REQUESTED
  CLOSED
}

enum ReadingEventType {
  CREATED
  SUBMITTED
  VALIDATED
  FLAGGED
  REJECTED
  RESUBMITTED
  TASK_CREATED
  TASK_UPDATED
  OCR_PROCESSED
  ANOMALY_DETECTED
}

enum TaskType {
  FIELD_RECHECK
  FRAUD_INVESTIGATION
  METER_VERIFICATION
  GENERAL
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskResolutionCode {
  READING_CONFIRMED
  READING_IMPOSSIBLE
  METER_INACCESSIBLE
  METER_DAMAGED_OR_MISSING
  SUSPECTED_FRAUD
  CUSTOMER_ABSENT
  ESCALATION_REQUIRED
}

enum TaskEventType {
  ASSIGNED
  STARTED
  BLOCKED
  COMPLETED
  FIELD_RESULT_SUBMITTED
}

enum TaskItemStatus {
  TODO
  DONE
  CANCELED
}

enum BillingCampaignStatus {
  DRAFT
  READY
  RUNNING
  GENERATED
  ISSUED
  CLOSED
  CANCELED
}

enum TariffBillingMode {
  SINGLE_RATE
  TIME_OF_USE
}

enum ServiceUsageCategory {
  RESIDENTIAL
  PROFESSIONAL
  ADMINISTRATION
  INDUSTRIAL
  PUBLIC_LIGHTING
}

enum ServicePowerUnit {
  AMPERE
  KVA
  KW
  KWH
}

enum ServicePhaseType {
  SINGLE_PHASE
  THREE_PHASE
}

enum ServiceContractSource {
  ADMIN
  IMPORT
  SYSTEM
}

enum TaxRuleType {
  PERCENT
  FIXED
}

enum TaxApplicationScope {
  CONSUMPTION
  FIXED_CHARGE
  SUBTOTAL
}

enum InvoiceStatus {
  DRAFT
  PENDING_REVIEW
  ISSUED
  DELIVERED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELED
}

enum InvoiceLineType {
  CONSUMPTION
  FIXED_FEE
  TAX
  ADJUSTMENT
  PENALTY
}

enum DeliveryChannel {
  SMS
  EMAIL
  PORTAL
  PRINT
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  CARD
  BANK_TRANSFER
  ADJUSTMENT
}

enum ReminderChannel {
  SMS
  EMAIL
  PUSH
}

enum ReminderStatus {
  SENT
  FAILED
  SKIPPED
}

enum OtpPurpose {
  LOGIN
  SIGNUP
  PASSWORD_RESET
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
  CANCELED
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  phone                   String                   @unique
  username                String?                  @unique
  email                   String?                  @unique
  passwordHash            String?                  @map("password_hash")
  firstName               String?                  @map("first_name")
  lastName                String?                  @map("last_name")
  role                    UserRole                 @default(CLIENT)
  status                  UserStatus               @default(PENDING)
  region                  String?
  city                    String?
  zone                    String?
  activatedAt             DateTime?                @map("activated_at")
  lastLoginAt             DateTime?                @map("last_login_at")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  deletedAt               DateTime?                @map("deleted_at")
  assignedMeters          Meter[]                  @relation("AgentMeters")
  meterAssignments        MeterAssignment[]        @relation("MeterAssignmentCustomer")
  createdMeterAssignments MeterAssignment[]        @relation("MeterAssignmentAssignedBy")
  endedMeterAssignments   MeterAssignment[]        @relation("MeterAssignmentEndedBy")
  serviceContracts        ServiceContract[]        @relation("ServiceContractCustomer")
  createdServiceContracts ServiceContract[]        @relation("ServiceContractCreatedBy")
  endedServiceContracts   ServiceContract[]        @relation("ServiceContractEndedBy")
  submittedReadings       Reading[]                @relation("ReadingSubmittedBy")
  reviewedReadings        Reading[]                @relation("ReadingReviewedBy")
  readingEvents           ReadingEvent[]
  assignedTasks           Task[]                   @relation("TaskAssignedTo")
  createdTasks            Task[]                   @relation("TaskCreatedBy")
  closedTasks             Task[]                   @relation("TaskClosedBy")
  startedTasks            Task[]                   @relation("TaskStartedBy")
  taskEventsAsActor       TaskEvent[]              @relation("TaskEventActor")
  taskEventsAsRecipient   TaskEvent[]              @relation("TaskEventRecipient")
  completedTaskItems      TaskItem[]               @relation("TaskItemCompletedBy")
  taskComments            TaskComment[]
  taskAttachments         TaskAttachment[]
  otpCodes                OtpCode[]
  authSessions            AuthSession[]
  roleAssignments         UserRoleAssignment[]     @relation("UserAssignedRoles")
  grantedRoleAssignments  UserRoleAssignment[]     @relation("UserGrantedRoles")
  billingCampaigns        BillingCampaign[]        @relation("BillingCampaignCreatedBy")
  billedInvoices          Invoice[]                @relation("InvoiceCustomer")
  generatedInvoices       Invoice[]                @relation("InvoiceGeneratedBy")
  approvedInvoices        Invoice[]                @relation("InvoiceApprovedBy")
  canceledInvoices        Invoice[]                @relation("InvoiceCanceledBy")
  createdInvoiceEvents    InvoiceEvent[]
  receivedPayments        Payment[]                @relation("PaymentReceivedBy")
  deliveryLogs            InvoiceDelivery[]        @relation("InvoiceDeliveryTriggeredBy")
  readingReminderLogs     ReadingReminderLog[]
  mobilePushDevices       MobilePushDevice[]
  customerNotifications   CustomerNotification[]
  mobileNotificationReads MobileNotificationRead[]
  agentNotificationReads  AgentNotificationRead[]

  @@index([role, status])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id              String               @id @default(uuid()) @db.Uuid
  code            String               @unique
  name            String
  description     String?
  isSystem        Boolean              @default(true) @map("is_system")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  deletedAt       DateTime?            @map("deleted_at")
  permissions     RolePermission[]
  userAssignments UserRoleAssignment[]

  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique
  name            String
  description     String?
  resource        String
  action          String
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  rolePermissions RolePermission[]

  @@index([resource, action])
  @@index([deletedAt])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@index([deletedAt])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  assignedById String?   @map("assigned_by_id") @db.Uuid
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  user         User      @relation("UserAssignedRoles", fields: [userId], references: [id])
  role         Role      @relation(fields: [roleId], references: [id])
  assignedBy   User?     @relation("UserGrantedRoles", fields: [assignedById], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([assignedById])
  @@index([deletedAt])
  @@map("user_role_assignments")
}

model City {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  name      String
  region    String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  zones     Zone[]

  @@index([name])
  @@index([isActive])
  @@index([deletedAt])
  @@map("cities")
}

model Zone {
  id                  String                @id @default(uuid()) @db.Uuid
  code                String                @unique
  name                String
  cityId              String                @map("city_id") @db.Uuid
  isActive            Boolean               @default(true) @map("is_active")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  deletedAt           DateTime?             @map("deleted_at")
  city                City                  @relation(fields: [cityId], references: [id])
  meters              Meter[]
  tariffPlans         TariffPlan[]
  campaignAssignments BillingCampaignZone[]
  taxRules            TaxRule[]

  @@index([cityId, name])
  @@index([isActive])
  @@index([deletedAt])
  @@map("zones")
}

model Meter {
  id               String            @id @default(uuid()) @db.Uuid
  serialNumber     String            @unique @map("serial_number")
  meterReference   String?           @unique @map("meter_reference")
  assignedAgentId  String?           @map("assigned_agent_id") @db.Uuid
  zoneId           String?           @map("zone_id") @db.Uuid
  type             MeterType         @default(SINGLE_INDEX)
  status           MeterStatus       @default(ACTIVE)
  addressLine1     String?           @map("address_line_1")
  addressLine2     String?           @map("address_line_2")
  city             String?
  zone             String?
  latitude         Decimal?          @db.Decimal(10, 7)
  longitude        Decimal?          @db.Decimal(10, 7)
  installedAt      DateTime?         @map("installed_at")
  lastInspectionAt DateTime?         @map("last_inspection_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")
  assignedAgent    User?             @relation("AgentMeters", fields: [assignedAgentId], references: [id])
  serviceZone      Zone?             @relation(fields: [zoneId], references: [id])
  assignments      MeterAssignment[]
  serviceContracts ServiceContract[]
  states           MeterState[]
  readings         Reading[]
  tasks            Task[]
  taskItems        TaskItem[]
  invoices         Invoice[]

  @@index([assignedAgentId])
  @@index([zoneId])
  @@index([status, city, zone])
  @@index([deletedAt])
  @@map("meters")
}

model MeterAssignment {
  id           String                @id @default(uuid()) @db.Uuid
  meterId      String                @map("meter_id") @db.Uuid
  customerId   String                @map("customer_id") @db.Uuid
  assignedById String?               @map("assigned_by_id") @db.Uuid
  endedById    String?               @map("ended_by_id") @db.Uuid
  source       MeterAssignmentSource @default(ADMIN)
  notes        String?
  assignedAt   DateTime              @default(now()) @map("assigned_at")
  endedAt      DateTime?             @map("ended_at")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  deletedAt    DateTime?             @map("deleted_at")
  meter        Meter                 @relation(fields: [meterId], references: [id])
  customer     User                  @relation("MeterAssignmentCustomer", fields: [customerId], references: [id])
  assignedBy   User?                 @relation("MeterAssignmentAssignedBy", fields: [assignedById], references: [id])
  endedBy      User?                 @relation("MeterAssignmentEndedBy", fields: [endedById], references: [id])

  @@index([meterId, assignedAt])
  @@index([meterId, endedAt])
  @@index([customerId, endedAt])
  @@index([assignedById])
  @@index([endedById])
  @@index([deletedAt])
  @@map("meter_assignments")
}

model ServiceContract {
  id                   String                @id @default(uuid()) @db.Uuid
  meterId              String                @map("meter_id") @db.Uuid
  customerId           String                @map("customer_id") @db.Uuid
  createdById          String?               @map("created_by_id") @db.Uuid
  endedById            String?               @map("ended_by_id") @db.Uuid
  contractNumber       String?               @unique @map("contract_number")
  policeNumber         String?               @unique @map("police_number")
  usageCategory        ServiceUsageCategory  @map("usage_category")
  billingMode          TariffBillingMode     @map("billing_mode")
  subscribedPowerValue Decimal               @map("subscribed_power_value") @db.Decimal(10, 3)
  subscribedPowerUnit  ServicePowerUnit      @default(AMPERE) @map("subscribed_power_unit")
  phaseType            ServicePhaseType      @default(SINGLE_PHASE) @map("phase_type")
  source               ServiceContractSource @default(ADMIN)
  effectiveFrom        DateTime              @map("effective_from")
  effectiveTo          DateTime?             @map("effective_to")
  notes                String?
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  deletedAt            DateTime?             @map("deleted_at")
  meter                Meter                 @relation(fields: [meterId], references: [id])
  customer             User                  @relation("ServiceContractCustomer", fields: [customerId], references: [id])
  createdBy            User?                 @relation("ServiceContractCreatedBy", fields: [createdById], references: [id])
  endedBy              User?                 @relation("ServiceContractEndedBy", fields: [endedById], references: [id])
  invoices             Invoice[]

  @@index([meterId, effectiveFrom, effectiveTo])
  @@index([customerId, effectiveFrom, effectiveTo])
  @@index([billingMode, usageCategory, subscribedPowerUnit, phaseType])
  @@index([deletedAt])
  @@map("service_contracts")
}

model MeterState {
  id                String    @id @default(uuid()) @db.Uuid
  meterId           String    @map("meter_id") @db.Uuid
  sourceReadingId   String?   @map("source_reading_id") @db.Uuid
  previousPrimary   Decimal?  @map("previous_primary") @db.Decimal(14, 3)
  previousSecondary Decimal?  @map("previous_secondary") @db.Decimal(14, 3)
  currentPrimary    Decimal?  @map("current_primary") @db.Decimal(14, 3)
  currentSecondary  Decimal?  @map("current_secondary") @db.Decimal(14, 3)
  effectiveAt       DateTime  @map("effective_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  meter             Meter     @relation(fields: [meterId], references: [id])
  sourceReading     Reading?  @relation(fields: [sourceReadingId], references: [id])

  @@index([meterId, effectiveAt])
  @@index([deletedAt, effectiveAt])
  @@index([sourceReadingId])
  @@index([deletedAt])
  @@map("meter_states")
}

model Reading {
  id                String         @id @default(uuid()) @db.Uuid
  meterId           String         @map("meter_id") @db.Uuid
  submittedById     String         @map("submitted_by_id") @db.Uuid
  reviewedById      String?        @map("reviewed_by_id") @db.Uuid
  source            ReadingSource  @default(CLIENT)
  status            ReadingStatus  @default(PENDING)
  readingAt         DateTime       @map("reading_at")
  primaryIndex      Decimal        @map("primary_index") @db.Decimal(14, 3)
  secondaryIndex    Decimal?       @map("secondary_index") @db.Decimal(14, 3)
  imageUrl          String         @map("image_url")
  imageHash         String?        @map("image_hash")
  imageMimeType     String?        @map("image_mime_type")
  imageSizeBytes    Int?           @map("image_size_bytes")
  gpsLatitude       Decimal?       @map("gps_latitude") @db.Decimal(10, 7)
  gpsLongitude      Decimal?       @map("gps_longitude") @db.Decimal(10, 7)
  gpsAccuracyMeters Decimal?       @map("gps_accuracy_meters") @db.Decimal(10, 2)
  gpsDistanceMeters Decimal?       @map("gps_distance_meters") @db.Decimal(10, 2)
  idempotencyKey    String?        @unique @map("idempotency_key")
  rejectionReason   String?        @map("rejection_reason")
  flagReason        String?        @map("flag_reason")
  confidenceScore   Decimal?       @map("confidence_score") @db.Decimal(5, 2)
  anomalyScore      Decimal?       @map("anomaly_score") @db.Decimal(6, 3)
  ocrText           String?        @map("ocr_text")
  reviewedAt        DateTime?      @map("reviewed_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")
  meter             Meter          @relation(fields: [meterId], references: [id])
  submittedBy       User           @relation("ReadingSubmittedBy", fields: [submittedById], references: [id])
  reviewedBy        User?          @relation("ReadingReviewedBy", fields: [reviewedById], references: [id])
  events            ReadingEvent[]
  meterStates       MeterState[]
  tasks             Task[]         @relation("TaskSourceReading")
  reportedTasks     Task[]         @relation("TaskReportedReading")
  taskItems         TaskItem[]
  invoices          Invoice[]      @relation("InvoiceSourceReading")
  fromInvoices      Invoice[]      @relation("InvoiceFromReading")
  toInvoices        Invoice[]      @relation("InvoiceToReading")

  @@index([meterId, status, readingAt])
  @@index([submittedById, status])
  @@index([reviewedById])
  @@index([deletedAt, createdAt])
  @@index([deletedAt, status, createdAt])
  @@index([deletedAt])
  @@map("readings")
}

model ReadingEvent {
  id                String                   @id @default(uuid()) @db.Uuid
  readingId         String                   @map("reading_id") @db.Uuid
  userId            String?                  @map("user_id") @db.Uuid
  type              ReadingEventType
  payload           Json                     @default("{}")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  deletedAt         DateTime?                @map("deleted_at")
  reading           Reading                  @relation(fields: [readingId], references: [id])
  user              User?                    @relation(fields: [userId], references: [id])
  notificationReads MobileNotificationRead[]

  @@index([readingId, type, createdAt])
  @@index([deletedAt, createdAt])
  @@index([userId])
  @@index([deletedAt])
  @@map("reading_events")
}

model Task {
  id                     String              @id @default(uuid()) @db.Uuid
  meterId                String?             @map("meter_id") @db.Uuid
  readingId              String?             @map("reading_id") @db.Uuid
  reportedReadingId      String?             @map("reported_reading_id") @db.Uuid
  assignedToId           String?             @map("assigned_to_id") @db.Uuid
  createdById            String?             @map("created_by_id") @db.Uuid
  closedById             String?             @map("closed_by_id") @db.Uuid
  startedById            String?             @map("started_by_id") @db.Uuid
  type                   TaskType            @default(GENERAL)
  status                 TaskStatus          @default(OPEN)
  priority               TaskPriority        @default(MEDIUM)
  resolutionCode         TaskResolutionCode? @map("resolution_code")
  title                  String
  description            String?
  resolutionComment      String?             @map("resolution_comment")
  dueAt                  DateTime?           @map("due_at")
  startedAt              DateTime?           @map("started_at")
  fieldSubmittedAt       DateTime?           @map("field_submitted_at")
  closedAt               DateTime?           @map("closed_at")
  fieldPrimaryIndex      Decimal?            @map("field_primary_index") @db.Decimal(14, 3)
  fieldSecondaryIndex    Decimal?            @map("field_secondary_index") @db.Decimal(14, 3)
  fieldImageUrl          String?             @map("field_image_url")
  fieldImageHash         String?             @map("field_image_hash")
  fieldImageMimeType     String?             @map("field_image_mime_type")
  fieldImageSizeBytes    Int?                @map("field_image_size_bytes")
  fieldGpsLatitude       Decimal?            @map("field_gps_latitude") @db.Decimal(10, 7)
  fieldGpsLongitude      Decimal?            @map("field_gps_longitude") @db.Decimal(10, 7)
  fieldGpsAccuracyMeters Decimal?            @map("field_gps_accuracy_meters") @db.Decimal(10, 2)
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  deletedAt              DateTime?           @map("deleted_at")
  meter                  Meter?              @relation(fields: [meterId], references: [id])
  reading                Reading?            @relation("TaskSourceReading", fields: [readingId], references: [id])
  reportedReading        Reading?            @relation("TaskReportedReading", fields: [reportedReadingId], references: [id])
  assignedTo             User?               @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  createdBy              User?               @relation("TaskCreatedBy", fields: [createdById], references: [id])
  closedBy               User?               @relation("TaskClosedBy", fields: [closedById], references: [id])
  startedBy              User?               @relation("TaskStartedBy", fields: [startedById], references: [id])
  items                  TaskItem[]
  comments               TaskComment[]
  attachments            TaskAttachment[]
  events                 TaskEvent[]

  @@index([status, priority, dueAt])
  @@index([deletedAt, createdAt])
  @@index([assignedToId])
  @@index([startedById])
  @@index([meterId, readingId])
  @@index([reportedReadingId])
  @@index([resolutionCode])
  @@index([deletedAt])
  @@map("tasks")
}

model TaskEvent {
  id                String                  @id @default(uuid()) @db.Uuid
  taskId            String                  @map("task_id") @db.Uuid
  actorUserId       String?                 @map("actor_user_id") @db.Uuid
  recipientUserId   String                  @map("recipient_user_id") @db.Uuid
  type              TaskEventType
  payload           Json?                   @default("{}")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  deletedAt         DateTime?               @map("deleted_at")
  task              Task                    @relation(fields: [taskId], references: [id])
  actorUser         User?                   @relation("TaskEventActor", fields: [actorUserId], references: [id])
  recipientUser     User                    @relation("TaskEventRecipient", fields: [recipientUserId], references: [id])
  notificationReads AgentNotificationRead[]

  @@index([taskId, createdAt])
  @@index([recipientUserId, createdAt])
  @@index([actorUserId])
  @@index([deletedAt])
  @@map("task_events")
}

model TaskItem {
  id            String         @id @default(uuid()) @db.Uuid
  taskId        String         @map("task_id") @db.Uuid
  readingId     String?        @map("reading_id") @db.Uuid
  meterId       String?        @map("meter_id") @db.Uuid
  completedById String?        @map("completed_by_id") @db.Uuid
  title         String
  details       String?
  status        TaskItemStatus @default(TODO)
  sortOrder     Int            @default(0) @map("sort_order")
  completedAt   DateTime?      @map("completed_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  task          Task           @relation(fields: [taskId], references: [id])
  reading       Reading?       @relation(fields: [readingId], references: [id])
  meter         Meter?         @relation(fields: [meterId], references: [id])
  completedBy   User?          @relation("TaskItemCompletedBy", fields: [completedById], references: [id])

  @@index([taskId, sortOrder])
  @@index([status, completedAt])
  @@index([deletedAt])
  @@map("task_items")
}

model TaskComment {
  id         String    @id @default(uuid()) @db.Uuid
  taskId     String    @map("task_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  comment    String
  isInternal Boolean   @default(true) @map("is_internal")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  task       Task      @relation(fields: [taskId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
  @@index([userId])
