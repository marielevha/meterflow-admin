  previousSecondary            Decimal?              @map("previous_secondary") @db.Decimal(14, 3)
  currentSecondary             Decimal?              @map("current_secondary") @db.Decimal(14, 3)
  consumptionPrimary           Decimal               @default(0) @map("consumption_primary") @db.Decimal(14, 3)
  consumptionSecondary         Decimal?              @default(0) @map("consumption_secondary") @db.Decimal(14, 3)
  isEstimated                  Boolean               @default(false) @map("is_estimated")
  estimationMethod             String?               @map("estimation_method")
  hasException                 Boolean               @default(false) @map("has_exception")
  subtotal                     Decimal               @default(0) @db.Decimal(14, 2)
  taxAmount                    Decimal               @default(0) @map("tax_amount") @db.Decimal(14, 2)
  fixedAmount                  Decimal               @default(0) @map("fixed_amount") @db.Decimal(14, 2)
  adjustmentAmount             Decimal               @default(0) @map("adjustment_amount") @db.Decimal(14, 2)
  totalAmount                  Decimal               @default(0) @map("total_amount") @db.Decimal(14, 2)
  paidAmount                   Decimal               @default(0) @map("paid_amount") @db.Decimal(14, 2)
  issuedAt                     DateTime?             @map("issued_at")
  deliveredAt                  DateTime?             @map("delivered_at")
  canceledAt                   DateTime?             @map("canceled_at")
  cycleFinalizedAt             DateTime?             @map("cycle_finalized_at")
  cancelReason                 String?               @map("cancel_reason")
  metadata                     Json?                 @default("{}")
  createdAt                    DateTime              @default(now()) @map("created_at")
  updatedAt                    DateTime              @updatedAt @map("updated_at")
  deletedAt                    DateTime?             @map("deleted_at")
  campaign                     BillingCampaign?      @relation(fields: [campaignId], references: [id])
  tariffPlan                   TariffPlan?           @relation(fields: [tariffPlanId], references: [id])
  serviceContract              ServiceContract?      @relation(fields: [serviceContractId], references: [id])
  customer                     User                  @relation("InvoiceCustomer", fields: [customerId], references: [id])
  meter                        Meter                 @relation(fields: [meterId], references: [id])
  sourceReading                Reading?              @relation("InvoiceSourceReading", fields: [sourceReadingId], references: [id])
  fromReading                  Reading?              @relation("InvoiceFromReading", fields: [fromReadingId], references: [id])
  toReading                    Reading?              @relation("InvoiceToReading", fields: [toReadingId], references: [id])
  generatedBy                  User?                 @relation("InvoiceGeneratedBy", fields: [generatedById], references: [id])
  approvedBy                   User?                 @relation("InvoiceApprovedBy", fields: [approvedById], references: [id])
  canceledBy                   User?                 @relation("InvoiceCanceledBy", fields: [canceledById], references: [id])
  lines                        InvoiceLine[]
  events                       InvoiceEvent[]
  payments                     Payment[]
  deliveries                   InvoiceDelivery[]

  @@unique([campaignId, meterId])
  @@index([campaignId, status])
  @@index([customerId, status, periodStart])
  @@index([meterId, periodStart, periodEnd])
  @@index([tariffPlanId])
  @@index([serviceContractId])
  @@index([sourceReadingId])
  @@index([fromReadingId])
  @@index([toReadingId])
  @@index([deletedAt])
  @@map("invoices")
}

