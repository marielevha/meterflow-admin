# App
NEXT_PUBLIC_APP_NAME=MeterFlow
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SHOW_DEMO_MENU=0
APP_PORT=3000

# Postgres
POSTGRES_DB=meterflow
POSTGRES_USER=meterflow
POSTGRES_PASSWORD=meterflow
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@maeva.com
PGADMIN_DEFAULT_PASSWORD=Maev@123
PGADMIN_PORT=8080

# Auth / security
JWT_SECRET=change-me-super-secret-key
JWT_ACCESS_TOKEN_TTL=60m
JWT_REFRESH_TOKEN_TTL=30d
OTP_CODE_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
CRON_SECRET=change-me-cron-secret

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_REGION=us-east-1
S3_BUCKET=meterflow
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/meterflow

# Optional integrations
SMS_PROVIDER=
SMS_SENDER_ID=MeterFlow
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
TWILIO_WHATSAPP_FROM=
RESEND_API_KEY=
MAILTRAP_API_KEY=
REMINDER_EMAIL_FROM=noreply@meterflow.local
REMINDER_PUSH_WEBHOOK_URL=
EXPO_ACCESS_TOKEN=

# Logs / feature flags
LOG_LEVEL=info
LOG_DIR=logs
LOG_MAX_FILE_SIZE_MB=10
LOG_MAX_FILES=10
LOG_TO_CONSOLE=1
FEATURE_OCR=false
FEATURE_ANOMALY_SCORING=false
