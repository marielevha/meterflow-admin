# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=MeterFlow
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (Prisma)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://maeva:Maev%40123@localhost:5432/meterflow?schema=public"
DIRECT_URL="postgresql://maeva:Maev%40123@localhost:5432/meterflow?schema=public"

# -----------------------------------------------------------------------------
# Auth / Security
# -----------------------------------------------------------------------------
JWT_SECRET="change-me-super-secret-key"
JWT_ACCESS_TOKEN_TTL="60m"
JWT_REFRESH_TOKEN_TTL="30d"
OTP_CODE_LENGTH="6"
OTP_TTL_SECONDS="300"
OTP_MAX_ATTEMPTS="5"

# -----------------------------------------------------------------------------
# Notifications / WhatsApp + SMS (Twilio)
# -----------------------------------------------------------------------------
SMS_PROVIDER="twilio"
SMS_SENDER_ID="MeterFlow"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_PHONE=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
RESEND_API_KEY="re_dbWwGkot_DpvognGd3Auasys8Hzt33m4i"
MAILTRAP_API_KEY="03b4ebaaf40615af6c8d89d7edc7f6a6"
REMINDER_EMAIL_FROM="noreply@meterflow.com"
REMINDER_PUSH_WEBHOOK_URL=""

# -----------------------------------------------------------------------------
# Cron jobs
# -----------------------------------------------------------------------------
CRON_SECRET="change-me-cron-secret"

# -----------------------------------------------------------------------------
# Storage (S3 compatible)
# -----------------------------------------------------------------------------
STORAGE_DRIVER="s3"
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="meterflow"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin123"
S3_FORCE_PATH_STYLE="true"

# -----------------------------------------------------------------------------
# Background jobs / Queue (phase 2)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"
BULLMQ_PREFIX="meterflow"

# -----------------------------------------------------------------------------
# Logging / Monitoring
# -----------------------------------------------------------------------------
LOG_LEVEL="debug"
SENTRY_DSN=""

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
FEATURE_OCR="false"
FEATURE_ANOMALY_SCORING="false"
